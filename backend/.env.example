# Copy this file to .env and fill in real values. Never commit the real .env.

# Database
DB_URL=jdbc:postgresql://localhost:5432/caagent
DB_USERNAME=caagent_user
DB_PASSWORD=changeme

# Redis (rate limiting + distributed state)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT - generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_IN_PRODUCTION_MIN_256_BITS
JWT_ACCESS_EXPIRY=900000
JWT_REFRESH_EXPIRY=604800000

# Google OAuth2 (console.cloud.google.com -> APIs & Services -> Credentials)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# CORS / frontend
CORS_ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_BASE_URL=http://localhost:5173

# Razorpay (dashboard.razorpay.com -> Settings -> API Keys)
RAZORPAY_KEY_ID=rzp_test_placeholder
RAZORPAY_KEY_SECRET=placeholder_secret
RAZORPAY_WEBHOOK_SECRET=placeholder_webhook_secret

# Anthropic (console.anthropic.com -> API Keys) - required for AI document extraction.
# The app fails to start with a clear error if this is missing.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

SERVER_PORT=8080
LOG_LEVEL=INFO

# Document uploads. Defaults to /tmp/caagent-uploads, which is fine for local dev but NOT
# safe on most PaaS platforms (Railway included): the platform can mount a fresh, root-owned
# tmpfs over /tmp at container start regardless of Dockerfile permissions, and even where
# writable, /tmp is wiped on every redeploy - uploaded documents would silently disappear.
# In production, point this at a real persistent, writable mount instead - e.g. a Railway
# Volume (Service -> Settings -> Volumes -> add one, then set this to its mount path).
LOCAL_STORAGE_DIR=/tmp/caagent-uploads

# Your own user id (from the users table) - grants access to the /app/admin page.
# Leave blank to disable admin visibility entirely.
ADMIN_USER_ID=
