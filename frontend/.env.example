# Leave unset for local dev (Vite proxy handles /api -> localhost:8080).
# Set this to your deployed backend URL for production builds, e.g.:
# VITE_API_BASE_URL=https://api.yourapp.com/api
VITE_API_BASE_URL=

# Your own user id (must match backend ADMIN_USER_ID) - shows the Admin nav link.
# This only controls whether the link is shown; the backend enforces access independently.
VITE_ADMIN_USER_ID=
